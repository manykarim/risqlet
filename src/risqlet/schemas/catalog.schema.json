{
  "$defs": {
    "CatalogEntry": {
      "additionalProperties": true,
      "properties": {
        "kind": {
          "$ref": "#/$defs/EntryKind"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "prompts": {
          "items": {
            "type": "string"
          },
          "maxItems": 3,
          "minItems": 1,
          "title": "Prompts",
          "type": "array"
        },
        "provenance": {
          "minLength": 1,
          "title": "Provenance",
          "type": "string"
        },
        "related": {
          "items": {
            "type": "string"
          },
          "title": "Related",
          "type": "array"
        },
        "slug": {
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "title": "Slug",
          "type": "string"
        },
        "summary": {
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "words": {
          "items": {
            "type": "string"
          },
          "title": "Words",
          "type": "array"
        }
      },
      "required": [
        "slug",
        "name",
        "kind",
        "summary",
        "prompts",
        "provenance"
      ],
      "title": "CatalogEntry",
      "type": "object"
    },
    "EntryKind": {
      "enum": [
        "aspect",
        "technique",
        "heuristic",
        "guideword-set"
      ],
      "title": "EntryKind",
      "type": "string"
    }
  },
  "$id": "https://risqlet.dev/schemas/v1/catalog.schema.json",
  "additionalProperties": true,
  "properties": {
    "attribution": {
      "minLength": 1,
      "title": "Attribution",
      "type": "string"
    },
    "entries": {
      "items": {
        "$ref": "#/$defs/CatalogEntry"
      },
      "minItems": 1,
      "title": "Entries",
      "type": "array"
    },
    "id": {
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "title": "Id",
      "type": "string"
    },
    "license": {
      "minLength": 1,
      "title": "License",
      "type": "string"
    },
    "notice": {
      "default": "",
      "title": "Notice",
      "type": "string"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "version": {
      "default": 1,
      "title": "Version",
      "type": "integer"
    }
  },
  "required": [
    "id",
    "title",
    "license",
    "attribution",
    "entries"
  ],
  "title": "CatalogPack",
  "type": "object"
}
